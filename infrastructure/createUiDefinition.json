{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/createUiDefinition.schema.json#",
  "handler": "Microsoft.Common.TextBox",
  "version": "1.0.0",
  "parameters": {
    "basics": [],
    "steps": [
      {
        "name": "settings",
        "label": "Deployment Settings",
        "elements": [
          {
            "name": "orgName",
            "type": "Microsoft.Common.TextBox",
            "label": "Organization Name",
            "defaultValue": "cf",
            "toolTip": "The organization name.",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "domainName",
            "type": "Microsoft.Common.TextBox",
            "label": "Domain Name",
            "defaultValue": "cumulus",
            "toolTip": "The domain name.",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "location",
            "type": "Microsoft.Common.DropDown",
            "label": "Location",
            "defaultValue": "uksouth",
            "toolTip": "The Azure region for deployment."
          },
          {
            "name": "envName",
            "type": "Microsoft.Common.TextBox",
            "label": "Environment Name",
            "defaultValue": "demo",
            "toolTip": "The environment name.",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "uniqueIdentifier",
            "type": "Microsoft.Common.TextBox",
            "label": "Unique Identifier",
            "defaultValue": "05",
            "toolTip": "A unique identifier for resource naming.",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "datalakeName",
            "type": "Microsoft.Common.TextBox",
            "label": "Data Lake Name Prefix",
            "defaultValue": "dls",
            "toolTip": "The prefix for the storage account name.",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "functionBlobName",
            "type": "Microsoft.Common.TextBox",
            "label": "Function Blob Name Prefix",
            "defaultValue": "st",
            "toolTip": "The prefix for the function app storage name.",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "firstDeployment",
            "type": "Microsoft.Common.CheckBox",
            "label": "First Deployment",
            "defaultValue": true,
            "toolTip": "Controls initial RBAC setup with security group."
          },
          {
            "name": "deployADF",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Azure Data Factory",
            "defaultValue": true
          },
          {
            "name": "deployWorkers",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Worker Pipelines",
            "defaultValue": false
          },
          {
            "name": "deployVM",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Virtual Machine",
            "defaultValue": false
          },
          {
            "name": "deploySQL",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy SQL Database",
            "defaultValue": true
          },
          {
            "name": "deployFunction",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Function App",
            "defaultValue": true
          },
          {
            "name": "deployNetworking",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Networking Resources",
            "defaultValue": true
          },
          {
            "name": "deployADBWorkspace",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Azure Databricks Workspace",
            "defaultValue": true
          },
          {
            "name": "deployADBCluster",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Azure Databricks Cluster",
            "defaultValue": false
          },
          {
            "name": "deployPAT",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Personal Access Token",
            "defaultValue": false
          },
          {
            "name": "setRoleAssignments",
            "type": "Microsoft.Common.CheckBox",
            "label": "Set Role Assignments",
            "defaultValue": true
          }
        ]
      }
    ],
    "outputs": {
      "parameters": {
        "orgName": "[steps('settings').orgName]",
        "domainName": "[steps('settings').domainName]",
        "location": "[steps('settings').location]",
        "envName": "[steps('settings').envName]",
        "uniqueIdentifier": "[steps('settings').uniqueIdentifier]",
        "datalakeName": "[steps('settings').datalakeName]",
        "functionBlobName": "[steps('settings').functionBlobName]",
        "firstDeployment": "[steps('settings').firstDeployment]",
        "deployADF": "[steps('settings').deployADF]",
        "deployWorkers": "[steps('settings').deployWorkers]",
        "deployVM": "[steps('settings').deployVM]",
        "deploySQL": "[steps('settings').deploySQL]",
        "deployFunction": "[steps('settings').deployFunction]",
        "deployNetworking": "[steps('settings').deployNetworking]",
        "deployADBWorkspace": "[steps('settings').deployADBWorkspace]",
        "deployADBCluster": "[steps('settings').deployADBCluster]",
        "deployPAT": "[steps('settings').deployPAT]",
        "setRoleAssignments": "[steps('settings').setRoleAssignments]"
      }
    }
  }
}
