{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/createUiDefinition.schema.json#",
  "handler": "Microsoft.Common.TextBox",
  "version": "1.0.0",
  "parameters": {
    "basics": [
      {
        "name": "location",
        "type": "Microsoft.Common.DropDown",
        "label": "Region",
        "defaultValue": "uksouth",
        "toolTip": "The Azure region where all resources will be deployed.",
        "constraints": { "required": true },
        "options": [
          { "label": "East US", "value": "eastus" },
          { "label": "East US 2", "value": "eastus2" },
          { "label": "Central US", "value": "centralus" },
          { "label": "North Central US", "value": "northcentralus" },
          { "label": "South Central US", "value": "southcentralus" },
          { "label": "West US", "value": "westus" },
          { "label": "West US 2", "value": "westus2" },
          { "label": "West US 3", "value": "westus3" },
          { "label": "Canada Central", "value": "canadacentral" },
          { "label": "Canada East", "value": "canadaeast" },
          { "label": "UK South", "value": "uksouth" },
          { "label": "UK West", "value": "ukwest" },
          { "label": "North Europe", "value": "northeurope" },
          { "label": "West Europe", "value": "westeurope" },
          { "label": "France Central", "value": "francecentral" },
          { "label": "France South", "value": "francesouth" },
          { "label": "Germany West Central", "value": "germanywestcentral" },
          { "label": "Germany North", "value": "germanynorth" },
          { "label": "Norway East", "value": "norwayeast" },
          { "label": "Norway West", "value": "norwaywest" },
          { "label": "Switzerland North", "value": "switzerlandnorth" },
          { "label": "Switzerland West", "value": "switzerlandwest" },
          { "label": "Sweden Central", "value": "swedencentral" },
          { "label": "Sweden South", "value": "swedensouth" },
          { "label": "East Asia", "value": "eastasia" },
          { "label": "Southeast Asia", "value": "southeastasia" },
          { "label": "Japan East", "value": "japaneast" },
          { "label": "Japan West", "value": "japanwest" },
          { "label": "Australia East", "value": "australiaeast" },
          { "label": "Australia Southeast", "value": "australiasoutheast" },
          { "label": "Australia Central", "value": "australiacentral" },
          { "label": "Australia Central 2", "value": "australiacentral2" },
          { "label": "Central India", "value": "centralindia" },
          { "label": "South India", "value": "southindia" },
          { "label": "West India", "value": "westindia" },
          { "label": "Korea Central", "value": "koreacentral" },
          { "label": "Korea South", "value": "koreasouth" },
          { "label": "South Africa North", "value": "southafricanorth" },
          { "label": "South Africa West", "value": "southafricawest" },
          { "label": "UAE North", "value": "uaenorth" },
          { "label": "UAE Central", "value": "uaecentral" },
          { "label": "Brazil South", "value": "brazilsouth" },
          { "label": "Brazil Southeast", "value": "brazilsoutheast" },
          { "label": "Qatar Central", "value": "qatarcentral" },
          { "label": "Israel Central", "value": "israelcentral" }
        ]
      }
    ],
    "steps": [
      {
        "name": "naming",
        "label": "Naming and Environment",
        "elements": [
          {
            "name": "orgName",
            "type": "Microsoft.Common.TextBox",
            "label": "Organization Name Prefix",
            "defaultValue": "cfc",
            "toolTip": "The naming prefix for all resources to be deployed.",
            "constraints": { "required": true }
          },
          {
            "name": "domainName",
            "type": "Microsoft.Common.TextBox",
            "label": "Domain Name",
            "defaultValue": "demo",
            "toolTip": "The optional middle part naming for all resources to be deployed. Suggested as the business unit, project or domain.",
            "constraints": { "required": true }
          },
          {
            "name": "envName",
            "type": "Microsoft.Common.DropDown",
            "label": "Environment",
            "defaultValue": "dev",
            "toolTip": "The environment name abbreviation used for the deployment.",
            "constraints": { "required": true },
            "options": [
              { "label": "Development", "value": "dev" },
              { "label": "Test", "value": "tst" },
              { "label": "Production", "value": "prd" }
            ]
          },
          {
            "name": "uniqueIdentifier",
            "type": "Microsoft.Common.TextBox",
            "label": "Unique Identifier",
            "defaultValue": "01",
            "toolTip": "The numeric identifier for all resources as a naming suffix, used to differentiate between instances of resources.",
            "constraints": { "required": true }
          }
        ]
      },
      {
        "name": "storage",
        "label": "Storage Settings",
        "elements": [
          {
            "name": "datalakeName",
            "type": "Microsoft.Common.TextBox",
            "label": "Data Lake Storage Name",
            "defaultValue": "dls",
            "toolTip": "Optional naming abbreviation for the Azure Data Lake Storage account.",
            "constraints": { "required": true }
          },
          {
            "name": "functionStorageName",
            "type": "Microsoft.Common.TextBox",
            "label": "Function Storage Name",
            "defaultValue": "st",
            "toolTip": "Optional naming abbreviation for the Azure Storage account used to support the Azure Functions App.",
            "constraints": { "required": true }
          }
        ]
      },
      {
        "name": "compute",
        "label": "Compute and Services",
        "elements": [
          {
            "name": "databricksSKU",
            "type": "Microsoft.Common.DropDown",
            "label": "Databricks SKU",
            "defaultValue": "Premium",
            "toolTip": "The product SKU for the Azure Databricks workspace.",
            "constraints": { "required": true },
            "options": [
              { "label": "Premium", "value": "Premium" },
              { "label": "Standard", "value": "Standard" }
            ]
          },
          {
            "name": "aspSKU",
            "type": "Microsoft.Common.DropDown",
            "label": "App Service Plan SKU",
            "defaultValue": "consumption",
            "toolTip": "The product SKU for the App Service Plan used by the Azure Function App.",
            "constraints": { "required": true },
            "options": [
              { "label": "Premium", "value": "premium" },
              { "label": "Consumption", "value": "consumption" }
            ]
          }
        ]
      },
      {
        "name": "options",
        "label": "Optional Deployments",
        "elements": [
          {
            "name": "deploySQLDacpac",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy SQL DACPAC",
            "defaultValue": true,
            "toolTip": "Deploy the SQL DACPAC required for the metadata database objects."
          },
          {
            "name": "deployADF",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Azure Data Factory",
            "defaultValue": true,
            "toolTip": "Optionally deploy Azure Data Factory."
          },
          {
            "name": "deployWorkers",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Worker Data Factory",
            "defaultValue": false,
            "toolTip": "Optionally deploy a separate Azure Data Factory instance to house Worker and Bootstrap pipelines separately."
          },
          {
            "name": "deploySQL",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Azure SQL Database",
            "defaultValue": true,
            "toolTip": "Optionally deploy an Azure SQL Database to house all metadata."
          },
          {
            "name": "deployFunction",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Azure Function App",
            "defaultValue": true,
            "toolTip": "Optionally deploy an Azure Function App."
          },
          {
            "name": "deployADBWorkspace",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Azure Databricks Workspace",
            "defaultValue": true,
            "toolTip": "Optionally deploy an Azure Databricks workspace."
          },
          {
            "name": "setRoleAssignments",
            "type": "Microsoft.Common.CheckBox",
            "label": "Set Role Assignments",
            "defaultValue": true,
            "toolTip": "Optionally setup role assignments as part of the deployment."
          },
          {
            "name": "deployNetworking",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Networking Resources",
            "defaultValue": false,
            "toolTip": "Optionally deploy a custom VNet for the Azure Databricks workspace."
          },
          {
            "name": "deployVM",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Virtual Machine for IR",
            "defaultValue": false,
            "toolTip": "Optionally deploy a Virtual Machine to house self-hosted Integration Runtime (IR) for Azure Data Factory."
          },
          {
            "name": "configureGitHub",
            "type": "Microsoft.Common.CheckBox",
            "label": "Configure GitHub for Data Factory",
            "defaultValue": false,
            "toolTip": "Optionally configure GitHub repository for Azure Data Factory."
          }
        ]
      },
      {
        "name": "sql",
        "label": "SQL Firewall and Access",
        "elements": [
          {
            "name": "myIPAddress",
            "type": "Microsoft.Common.TextBox",
            "label": "Your IP Address",
            "toolTip": "An external IP address that is allowed access to the Azure SQL Database, as part of the logical SQL instance Firewall Rules."
          },
          {
            "name": "allowAzureServices",
            "type": "Microsoft.Common.CheckBox",
            "label": "Allow Azure Services",
            "defaultValue": true,
            "toolTip": "Allow Azure services to access the Azure SQL Database, as part of the logical SQL instance Firewall Rules."
          }
        ]
      }
    ],
    "outputs": {
      "parameters": {
        "orgName": "[steps('naming').orgName]",
        "domainName": "[steps('naming').domainName]",
        "envName": "[steps('naming').envName]",
        "location": "[basics('location')]",
        "datalakeName": "[steps('storage').datalakeName]",
        "functionStorageName": "[steps('storage').functionStorageName]",
        "uniqueIdentifier": "[steps('naming').uniqueIdentifier]",
        "databricksSKU": "[steps('compute').databricksSKU]",
        "aspSKU": "[steps('compute').aspSKU]",
        "deploySQLDacpac": "[steps('options').deploySQLDacpac]",
        "myIPAddress": "[steps('sql').myIPAddress]",
        "allowAzureServices": "[steps('sql').allowAzureServices]",
        "deployADF": "[steps('options').deployADF]",
        "deployWorkers": "[steps('options').deployWorkers]",
        "deploySQL": "[steps('options').deploySQL]",
        "deployFunction": "[steps('options').deployFunction]",
        "deployADBWorkspace": "[steps('options').deployADBWorkspace]",
        "setRoleAssignments": "[steps('options').setRoleAssignments]",
        "deployNetworking": "[steps('options').deployNetworking]",
        "deployVM": "[steps('options').deployVM]",
        "configureGitHub": "[steps('options').configureGitHub]"
      }
    }
  }
}