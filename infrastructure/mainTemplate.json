{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "orgName": {
      "type": "string",
      "defaultValue": "cf",
      "metadata": {
        "description": "The organization name."
      }
    },
    "domainName": {
      "type": "string",
      "defaultValue": "cumulus",
      "metadata": {
        "description": "The domain name."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "uksouth",
      "metadata": {
        "description": "The Azure region for deployment."
      }
    },
    "envName": {
      "type": "string",
      "defaultValue": "demo",
      "metadata": {
        "description": "The environment name."
      }
    },
    "uniqueIdentifier": {
      "type": "string",
      "defaultValue": "05",
      "metadata": {
        "description": "A unique identifier for resource naming."
      }
    },
    "datalakeName": {
      "type": "string",
      "defaultValue": "dls",
      "metadata": {
        "description": "The prefix for the storage account name."
      }
    },
    "functionBlobName": {
      "type": "string",
      "defaultValue": "st",
      "metadata": {
        "description": "The prefix for the function app storage name."
      }
    },
    "firstDeployment": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Controls initial RBAC setup with security group."
      }
    },
    "deployADF": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Flag to deploy Azure Data Factory."
      }
    },
    "deployWorkers": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Flag to deploy worker pipelines in a separate Data Factory instance."
      }
    },
    "deployVM": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Flag to deploy a virtual machine."
      }
    },
    "deploySQL": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Flag to deploy SQL database."
      }
    },
    "deployFunction": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Flag to deploy function app."
      }
    },
    "deployNetworking": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Flag to deploy networking resources."
      }
    },
    "deployADBWorkspace": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Flag to deploy Azure Databricks workspace."
      }
    },
    "deployADBCluster": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Flag to deploy Azure Databricks cluster."
      }
    },
    "deployPAT": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Flag to deploy Personal Access Token for Databricks."
      }
    },
    "setRoleAssignments": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Flag to set role assignments."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deploymentScripts",
      "apiVersion": "2021-04-01",
      "name": "mainDeployment",
      "properties": {
        "azCliVersion": "2.0",
        "scriptContent": "[parameters('main.bicep')]",
        "arguments": "[parameters('orgName'), parameters('domainName'), parameters('location'), parameters('envName'), parameters('uniqueIdentifier'), parameters('datalakeName'), parameters('functionBlobName'), parameters('firstDeployment'), parameters('deployADF'), parameters('deployWorkers'), parameters('deployVM'), parameters('deploySQL'), parameters('deployFunction'), parameters('deployNetworking'), parameters('deployADBWorkspace'), parameters('deployADBCluster'), parameters('deployPAT'), parameters('setRoleAssignments')]"
      }
    }
  ],
  "outputs": {}
}